# Copie este arquivo para ".env" e preencha com os dados do seu projeto Supabase
# (Project Settings > API). O ".env" NUNCA deve ser commitado — já está no .gitignore.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-public

# Base path para build de produção (usado pelo GitHub Actions).
# Se o repositório for "portfolio", use /portfolio/.
# Se o repositório for <seu-usuario>.github.io, use /.
VITE_BASE_PATH=/portfolio/
